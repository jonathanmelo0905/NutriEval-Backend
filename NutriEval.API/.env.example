# ============================================================
# NutriEval API — Variables de entorno requeridas
# Copia este archivo a .env y completa los valores reales.
# NUNCA commitees el archivo .env con valores reales.
# ============================================================

# Base de datos (Railway provee este formato automáticamente)
DATABASE_URL=postgresql://user:password@host:5432/database

# JWT
JWT_SECRET=cambia-esto-por-un-secreto-seguro-de-al-menos-32-caracteres
JWT_ISSUER=nutrieval-api
JWT_AUDIENCE=nutrieval-app
JWT_EXPIRES_HOURS=24

# Cloudinary (cloud: dnj3zphoj)
CLOUDINARY_CLOUD_NAME=dnj3zphoj
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# CORS — URL del frontend Angular
FRONTEND_URL=https://nutrieval-app.web.app
